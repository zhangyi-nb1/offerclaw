# OfferClaw local API configuration.
# Copy this file to .env.local and fill keys locally. Never commit .env.local.

# -----------------------------------------------------
# Chat / Agent / resume / planning LLM
# -----------------------------------------------------
# Bailian / DashScope OpenAI-compatible mode:
OPENAI_API_KEY=your_dashscope_api_key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus-2025-07-28
# RAG answer synthesis model. Keep it on Bailian free quota too.
RAG_SYNTH_MODEL=qwen-plus-2025-07-28
LLM_REASONING_EFFORT=
LLM_TIMEOUT=60

# -----------------------------------------------------
# RAG embedding provider
# -----------------------------------------------------
# Bailian text embedding. Keep this collection separate from old Zhipu vectors.
EMBEDDING_PROVIDER=bailian
DASHSCOPE_API_KEY=your_dashscope_api_key
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
RAG_COLLECTION_NAME=offerclaw_bailian_text_embedding_v4_1024

# -----------------------------------------------------
# Legacy Zhipu fallback
# -----------------------------------------------------
# EMBEDDING_PROVIDER=zhipu
# ZHIPU_API_KEY=your_key_id.your_signing_secret
# EMBEDDING_MODEL=embedding-3
# RAG_COLLECTION_NAME=offerclaw_docs
